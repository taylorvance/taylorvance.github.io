{
	"name": "TV Programs",
	"private": true,
	"version": "2.0.0",
	"type": "module",
	"scripts": {
		"clean": "rm -rf node_modules dist coverage .vite .eslintcache *.tsbuildinfo",
		"dev": "vite --host",
		"build": "tsc -b && vite build",
		"verify": "npm run lint && npm run test && npm run build",
		"verify:push": "npm run verify",
		"prepare": "simple-git-hooks",
		"lint": "eslint . --report-unused-disable-directives --max-warnings 0",
		"preview": "vite preview",
		"test": "vitest --run",
		"test:watch": "vitest"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged",
		"pre-push": "npm run verify:push"
	},
	"lint-staged": {
		"*.{js,mjs,cjs,ts,tsx}": "eslint --fix"
	},
	"dependencies": {
		"@taylorvance/tv-shared-web": "^0.7.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-icons": "^5.3.0"
	},
	"devDependencies": {
		"@taylorvance/tv-shared-dev": "^0.1.1",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.1.0",
		"@types/react": "^18.3.3",
		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^4.3.1",
		"autoprefixer": "^10.4.20",
		"daisyui": "^4.12.10",
		"eslint": "^9.39.1",
		"jsdom": "^25.0.1",
		"lint-staged": "^16.4.0",
		"postcss": "^8.4.45",
		"simple-git-hooks": "^2.13.1",
		"tailwindcss": "^3.4.10",
		"typescript": "^5.9.3",
		"vite": "^5.4.1",
		"vitest": "^2.1.8"
	}
}
